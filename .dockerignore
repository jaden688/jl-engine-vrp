# Docker build cache optimization & security
#
# Patterns to exclude from image build context.
# These reduce image size and build time.

# Version control
.git
.gitignore
.gitattributes

# IDE & editors
.vscode/
.vs/
.idea/
*.swp
*.swo
*~
.DS_Store

# CI/CD
.github/
.gitlab-ci.yml
.circleci/

# Documentation (loaded separately if needed)
*.md
CHANGELOG*
LICENSE
NOTICE

# Development & temporary files
.env
.env.*.local
*.log
*.out.log
*.err.log

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.Python
.pytest_cache/
.tox/
.coverage
htmlcov/
.venv/
venv/
env/

# Node.js (if applicable)
node_modules/
npm-debug.log
yarn-error.log

# Julia
.CondaPkg/

# Data & artifacts
*.db
*.sqlite
*.sqlite3
*.jsonl
full_telemetry.jsonl
demo.txt

# Images & media
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.mp4
*.webm

# Directories with non-essential content
JulianMetaMorph/
legacy/
landing/
reports/
test/
infra/
.azure/

# Browser profiles & caches
.sparkbyte-browser-profile/
_mcp_inspect/
elevenlabs-mcp/

# Local runtime state
data/images/
boot_stdout.txt
boot_stderr.txt
live_boot.txt
.scanossrc
.mcp.json
sparkbyte_memory.db
sparkbyte_*.png
cyber_grid*.png
sparkbyte_art.png
run_demo.bat
start_dashboard.bat
start_agentverse.bat
generate_bass.py
secret.mystic

# Exclude actual build artifacts (necessary for runtime)
!mcp_server/
!src/
!BYTE/
!bridge/
!ui/
!web/
!upgrades/
!assets/
