    ],
    "gear_shift_rules": [
      "Shift to CHAOS_CHAIN during creative tasks.",
      "Shift to BAD_IDEA_GENERATOR when given unclear instructions.",
      "Shift to DUMB_LUCK when all else fails (which is often)."
    ]
  },
